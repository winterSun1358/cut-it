.page {
  height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 用户信息头部 */
.profile-header {
  background: linear-gradient(135deg, #07c160, #06ad56);
  padding: 40rpx 30rpx 60rpx;
  flex-shrink: 0;
}

.profile-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.profile-title { font-size: 36rpx; font-weight: 700; color: #fff; }

.edit-btn {
  background: rgba(255,255,255,0.2); color: #fff; font-size: 24rpx;
  line-height: 52rpx; height: 52rpx; padding: 0 24rpx;
  border: 1rpx solid rgba(255,255,255,0.3); border-radius: 26rpx;
}

.profile-info { display: flex; align-items: center; }

.avatar-btn { padding: 0; margin: 0; background: transparent; border: none; line-height: 1; width: auto; height: auto; }

.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0; margin-right: 24rpx;
}

.info-display { flex: 1; }
.nickname { font-size: 36rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 8rpx; }

.quota-section { display: flex; align-items: baseline; }
.quota-value { font-size: 48rpx; font-weight: 700; color: #fff; margin-right: 8rpx; }
.quota-unit { font-size: 26rpx; color: rgba(255,255,255,0.8); }

/* 编辑模式 */
.edit-fields { flex: 1; }

.nickname-input {
  width: 100%; height: 72rpx; background: rgba(255,255,255,0.9);
  border-radius: 8rpx; padding: 0 16rpx; font-size: 28rpx; color: #333;
  box-sizing: border-box; margin-bottom: 16rpx;
}

.edit-actions { display: flex; gap: 16rpx; }

.cancel-btn {
  background: rgba(255,255,255,0.2); color: #fff; font-size: 24rpx;
  line-height: 56rpx; height: 56rpx; padding: 0 32rpx;
  border: 1rpx solid rgba(255,255,255,0.3); border-radius: 28rpx;
}

.save-btn {
  background: #fff; color: #07c160; font-size: 24rpx; font-weight: 600;
  line-height: 56rpx; height: 56rpx; padding: 0 32rpx;
  border: none; border-radius: 28rpx;
}

/* 内容区块 */
.section {
  background: #fff;
  margin: -40rpx 20rpx 0;
  border-radius: 20rpx 20rpx 0 0;
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title { font-size: 30rpx; font-weight: 600; color: #333; }
.section-count { font-size: 24rpx; color: #999; }

/* 状态筛选栏 */
.link-filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 6rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-item.active {
  color: #fff;
  background: #07c160;
  font-weight: 600;
}

.loading { text-align: center; padding: 40rpx; color: #999; }
.empty { text-align: center; padding: 60rpx; color: #bbb; font-size: 28rpx; }

.link-item { padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.link-item:last-child { border-bottom: none; }

.link-info {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx;
}

.link-title {
  font-size: 28rpx; color: #333; font-weight: 500; flex: 1;
  margin-right: 16rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

.link-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; }
.link-status.active { background: #f0f8ff; color: #07c160; }
.link-status.deleted, .link-status.expired { background: #f5f5f5; color: #999; }

.link-url { margin-bottom: 12rpx; }
.url-text { font-size: 24rpx; color: #999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; }
.link-actions { display: flex; justify-content: flex-end; gap: 12rpx; }

.expire-btn {
  background: #fff8e6; color: #e68a00; font-size: 22rpx;
  border: 1rpx solid #ffe0a0; padding: 0 24rpx;
  line-height: 48rpx; height: 48rpx; border-radius: 24rpx;
}

.delete-btn {
  background: #fff5f5; color: #ff6b6b; font-size: 22rpx;
  border: 1rpx solid #ffd0d0; padding: 0 24rpx;
  line-height: 48rpx; height: 48rpx; border-radius: 24rpx;
}

/* ====== 管理员入口 ====== */
.admin-section {
  margin-top: 20rpx;
  border-radius: 20rpx;
  flex: 0;
  cursor: pointer;
  user-select: none;
}

.report-entry-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

.admin-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: -8rpx;
}

/* 底部TabBar */
.tabbar {
  display: flex; background: #fff; border-top: 1rpx solid #eee;
  flex-shrink: 0; padding-bottom: env(safe-area-inset-bottom);
}

.tabbar .tab-item {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 24rpx 0; font-size: 26rpx; color: #999;
}

.tabbar .tab-item.active { color: #07c160; font-weight: 600; }
