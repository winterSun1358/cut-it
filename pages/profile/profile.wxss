/* ========== 我的页面 ========== */
.page {
  height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

/* ---------- 用户信息头部 ---------- */
.profile-header {
  background: var(--color-primary-gradient);
  padding: 40rpx 30rpx 80rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

/* 装饰圆 */
.profile-header::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -60rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  pointer-events: none;
}

.profile-header::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  pointer-events: none;
}

.profile-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.profile-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.edit-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 22rpx;
  line-height: 50rpx;
  height: 50rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
  border-radius: 25rpx;
  backdrop-filter: blur(4rpx);
}

.edit-btn:active {
  background: rgba(255,255,255,0.3);
}

.profile-info {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  width: auto;
  height: auto;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.info-display {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.quota-section {
  display: flex;
  align-items: baseline;
}

.quota-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 8rpx;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.quota-unit {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ---------- 编辑模式 ---------- */
.edit-fields {
  flex: 1;
}

.nickname-input {
  width: 100%;
  height: 72rpx;
  background: rgba(255,255,255,0.95);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.edit-actions {
  display: flex;
  gap: 16rpx;
}

.cancel-btn {
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 24rpx;
  line-height: 56rpx;
  height: 56rpx;
  padding: 0 32rpx;
  border: 1rpx solid rgba(255,255,255,0.3);
  border-radius: 28rpx;
}

.save-btn {
  background: #fff;
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
  height: 56rpx;
  padding: 0 32rpx;
  border: none;
  border-radius: 28rpx;
}

/* ---------- 内容区块 ---------- */
.section {
  background: var(--color-bg-card);
  margin: -60rpx 20rpx 0;
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  position: relative;
  z-index: 2;
  box-shadow: var(--shadow-lg);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.section-count {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  background: var(--color-bg-input);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ---------- 状态筛选栏 ---------- */
.link-filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.filter-item {
  padding: 8rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-input);
  transition: all 0.3s ease;
  font-weight: 500;
}

.filter-item.active {
  color: #fff;
  background: var(--color-primary-gradient);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(224, 112, 64, 0.25);
}

/* ---------- 加载/空状态 ---------- */
.loading {
  text-align: center;
  padding: 60rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 80rpx;
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

/* ---------- 链接列表 ---------- */
.link-item {
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  transition: background 0.2s ease;
  border-radius: var(--radius-sm);
  margin-bottom: 4rpx;
}

.link-item:last-child {
  border-bottom: none;
}

.link-item:active {
  background: var(--color-bg-input);
}

.link-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.link-title {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-status {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.link-status.active {
  background: var(--color-accent-light);
  color: var(--color-accent);
}

.link-status.deleted,
.link-status.expired {
  background: var(--color-bg-input);
  color: var(--color-text-tertiary);
}

.link-url {
  margin-bottom: 14rpx;
}

.url-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  background: var(--color-bg-input);
  padding: 10rpx 16rpx;
  border-radius: var(--radius-sm);
}

.link-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.expire-btn {
  background: #FFF8E6;
  color: #C58A00;
  font-size: 22rpx;
  border: 1rpx solid rgba(197, 138, 0, 0.2);
  padding: 0 24rpx;
  line-height: 50rpx;
  height: 50rpx;
  border-radius: 25rpx;
  font-weight: 500;
}

.expire-btn:active {
  background: rgba(197, 138, 0, 0.12);
}

.delete-btn {
  background: var(--color-danger-light);
  color: var(--color-danger);
  font-size: 22rpx;
  border: 1rpx solid rgba(217, 74, 90, 0.2);
  padding: 0 24rpx;
  line-height: 50rpx;
  height: 50rpx;
  border-radius: 25rpx;
  font-weight: 500;
}

.delete-btn:active {
  background: rgba(217, 74, 90, 0.15);
}

/* ---------- 管理员入口 ---------- */
.admin-section {
  margin-top: 20rpx;
  border-radius: var(--radius-xl);
  flex: 0;
  cursor: pointer;
  user-select: none;
  border: 1rpx solid rgba(224, 112, 64, 0.15);
}

.report-entry-arrow {
  font-size: 36rpx;
  color: var(--color-primary);
  font-weight: 300;
}

.admin-hint {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-top: -12rpx;
}

/* ---------- 底部TabBar ---------- */
.tabbar {
  display: flex;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  flex-shrink: 0;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 12rpx rgba(44, 40, 36, 0.04);
}

.tabbar .tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  position: relative;
  font-weight: 500;
}

.tabbar .tab-item.active {
  color: var(--color-primary);
  font-weight: 700;
}

.tabbar .tab-item.active::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary-gradient);
  border-radius: 0 0 4rpx 4rpx;
}
