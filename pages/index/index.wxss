/* ========== 助力大厅 ========== */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
}

/* ---------- 顶部导航 ---------- */
.header {
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.header::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -12rpx;
  height: 12rpx;
  background: linear-gradient(to bottom, rgba(0,0,0,0.03), transparent);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  min-height: 44rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 0.5px;
}

.header-title::before {
  content: '✦ ';
  color: var(--color-primary);
  font-size: 28rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 管理员按钮 */
.admin-btn {
  display: flex;
  align-items: center;
  background: var(--color-primary-light);
  padding: 8rpx 18rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(224, 112, 64, 0.2);
}

.admin-btn-text {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 600;
}

/* 额度徽章 */
.quota-badge {
  display: flex;
  align-items: center;
  background: var(--color-accent-light);
  padding: 8rpx 18rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(58, 125, 116, 0.2);
}

.quota-text {
  font-size: 24rpx;
  color: var(--color-accent);
  font-weight: 600;
}

/* ---------- 平台筛选标签 ---------- */
.platform-tabs {
  background: var(--color-bg-card);
  white-space: nowrap;
  padding: 12rpx 24rpx 16rpx;
  flex-shrink: 0;
}

.platform-tabs .tab-item {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 30rpx;
  margin-right: 12rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-input);
  transition: all 0.3s ease;
}

.platform-tabs .tab-item.active {
  color: #fff;
  background: var(--color-primary-gradient);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(224, 112, 64, 0.3);
}

/* ---------- 列表 ---------- */
.list {
  flex: 1;
  overflow-y: scroll;
  padding: 20rpx 20rpx 0;
}

.login-prompt {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  font-size: 56rpx;
  background: var(--color-bg-input);
  color: var(--color-text-tertiary);
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* ---------- 链接卡片 ---------- */
.link-list {
  padding-bottom: 20rpx;
}

.link-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border-light);
  transition: box-shadow 0.3s ease;
}

.link-card:active {
  box-shadow: var(--shadow-md);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
  border: 2rpx solid var(--color-border-light);
}

.publisher-name {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 平台标签 */
.platform-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.tag-pdd { background: #FFF0E6; color: #E07040; }
.tag-douyin { background: #E6F7FF; color: #0088CC; }
.tag-taobao { background: #FFF0F0; color: #FF4400; }
.tag-jd { background: #FFF8E6; color: #C55A2E; }
.tag-kuaishou { background: #F0FFF4; color: #E07040; }
.tag-xiaohongshu { background: #FFF0F5; color: #FF2442; }
.tag-qita { background: var(--color-bg-input); color: var(--color-text-tertiary); }

/* 卡片正文 */
.card-body {
  margin-bottom: 20rpx;
}

.link-title {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: 600;
  line-height: 1.5;
  word-break: break-all;
  display: block;
  margin-bottom: 10rpx;
}

.link-url {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
  word-break: break-all;
  display: block;
  background: var(--color-bg-input);
  padding: 14rpx 18rpx;
  border-radius: var(--radius-sm);
  position: relative;
  padding-left: 42rpx;
}

.link-url::before {
  content: '🔗';
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.report-btn {
  background: transparent;
  color: var(--color-text-tertiary);
  font-size: 22rpx;
  padding: 0 20rpx;
  line-height: 50rpx;
  height: 50rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 25rpx;
}

.report-btn:active {
  background: var(--color-bg-input);
}

.delete-btn {
  background: var(--color-danger-light);
  color: var(--color-danger);
  font-size: 22rpx;
  padding: 0 20rpx;
  line-height: 50rpx;
  height: 50rpx;
  border: 1rpx solid rgba(217, 74, 90, 0.2);
  border-radius: 25rpx;
}

.delete-btn:active {
  background: rgba(217, 74, 90, 0.15);
}

.copy-btn {
  background: var(--color-primary-gradient);
  color: #fff;
  font-size: 24rpx;
  padding: 0 36rpx;
  border-radius: 30rpx;
  line-height: 60rpx;
  height: 60rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(224, 112, 64, 0.25);
  transition: all 0.3s ease;
}

.copy-btn:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(224, 112, 64, 0.15);
}

.copy-btn.copied {
  background: var(--color-bg-input);
  color: var(--color-text-tertiary);
  box-shadow: none;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}

/* ---------- 底部TabBar ---------- */
.tabbar {
  display: flex;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  flex-shrink: 0;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 12rpx rgba(44, 40, 36, 0.04);
}

.tabbar .tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  position: relative;
  font-weight: 500;
}

.tabbar .tab-item.active {
  color: var(--color-primary);
  font-weight: 700;
}

.tabbar .tab-item.active::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary-gradient);
  border-radius: 0 0 4rpx 4rpx;
}
