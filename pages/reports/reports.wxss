.page {
  height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.header {
  background: #fff;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  height: 44rpx;
}

.header-left, .header-right {
  width: 120rpx;
}

.header-right {
  text-align: right;
}

.back-btn {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.refresh-btn {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
}

/* 内容区 */
.content {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}

.empty-icon {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 48rpx;
  background: #f0f8ff;
  color: #07c160;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.stats-bar {
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}

.stats-text {
  font-size: 26rpx;
  color: #888;
}

/* 举报卡片 */
.report-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 260rpx;
}

.report-badge {
  font-size: 22rpx;
  color: #fff;
  background: #ff6b6b;
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.card-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.link-status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.link-status-tag.active { background: #f0f8ff; color: #07c160; }
.link-status-tag.deleted, .link-status-tag.expired { background: #f5f5f5; color: #999; }

.expand-icon {
  font-size: 24rpx;
  color: #bbb;
}

/* 详情区域 */
.card-detail {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-section {
  margin-bottom: 12rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 24rpx;
}

.detail-label {
  color: #888;
  width: 140rpx;
  flex-shrink: 0;
}

.detail-value {
  color: #333;
  flex: 1;
  word-break: break-all;
}

.selectable {
  user-select: text;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 12rpx 0;
}

.section-label {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 8rpx;
}

.reason-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.reason-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #fafafa;
  border: 1rpx solid #eee;
  border-radius: 16rpx;
  padding: 6rpx 16rpx;
}

.reason-name {
  font-size: 24rpx;
  color: #555;
}

.reason-sep {
  font-size: 24rpx;
  color: #ddd;
}

.reason-count {
  font-size: 24rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.reporter-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.reporter-tag {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.detail-actions {
  margin-top: 8rpx;
}

.delete-link-btn {
  width: 100%;
  background: #fff2f2;
  color: #ff4444;
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid #ffcccc;
  border-radius: 24rpx;
  line-height: 64rpx;
  height: 64rpx;
}
