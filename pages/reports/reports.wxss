/* ========== 举报管理页面 ========== */
.page {
  height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

/* ---------- 顶部导航 ---------- */
.header {
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  min-height: 44rpx;
}

.header-left, .header-right {
  width: 120rpx;
}

.header-right { text-align: right; }

.back-btn {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.refresh-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
  background: var(--color-primary-light);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.refresh-btn:active {
  background: rgba(224, 112, 64, 0.15);
}

/* ---------- 内容区 ---------- */
.content {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.loading {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  font-size: 48rpx;
  background: var(--color-accent-light);
  color: var(--color-accent);
  border-radius: 50%;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(58, 125, 116, 0.15);
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* ---------- 统计栏 ---------- */
.stats-bar {
  padding: 8rpx 8rpx 16rpx;
}

.stats-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  background: var(--color-bg-input);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* ---------- 举报卡片 ---------- */
.report-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border-light);
  transition: box-shadow 0.3s ease;
}

.report-card:active {
  box-shadow: var(--shadow-md);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 240rpx;
}

.report-badge {
  font-size: 20rpx;
  color: #fff;
  background: var(--color-danger);
  padding: 2rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(217, 74, 90, 0.3);
}

.card-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.link-status-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.link-status-tag.active {
  background: var(--color-accent-light);
  color: var(--color-accent);
}

.link-status-tag.deleted,
.link-status-tag.expired {
  background: var(--color-bg-input);
  color: var(--color-text-tertiary);
}

.expand-icon {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  transition: transform 0.2s ease;
}

/* ---------- 详情区域 ---------- */
.card-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
  animation: fadeSlideIn 0.25s ease;
}

@keyframes fadeSlideIn {
  from { opacity: 0; transform: translateY(-8rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.detail-section {
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.detail-label {
  color: var(--color-text-tertiary);
  width: 140rpx;
  flex-shrink: 0;
}

.detail-value {
  color: var(--color-text);
  flex: 1;
  word-break: break-all;
}

.selectable {
  user-select: text;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border-light);
  margin: 16rpx 0;
}

.section-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

/* 举报原因列表 */
.reason-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.reason-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: var(--color-primary-light);
  border: 1rpx solid rgba(224, 112, 64, 0.15);
  border-radius: 16rpx;
  padding: 6rpx 18rpx;
}

.reason-name {
  font-size: 24rpx;
  color: var(--color-primary-dark);
}

.reason-sep {
  font-size: 22rpx;
  color: rgba(224, 112, 64, 0.2);
}

.reason-count {
  font-size: 24rpx;
  color: var(--color-danger);
  font-weight: 700;
}

/* 举报人列表 */
.reporter-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.reporter-tag {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-input);
  padding: 6rpx 18rpx;
  border-radius: 16rpx;
}

/* 操作按钮 */
.detail-actions {
  margin-top: 16rpx;
}

.delete-link-btn {
  width: 100%;
  background: var(--color-danger-light);
  color: var(--color-danger);
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid rgba(217, 74, 90, 0.2);
  border-radius: 28rpx;
  line-height: 68rpx;
  height: 68rpx;
  transition: all 0.2s ease;
}

.delete-link-btn:active {
  background: rgba(217, 74, 90, 0.15);
  transform: scale(0.97);
}
