.page {
  height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  background: #fff;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  height: 44rpx;
}

.header-title { font-size: 32rpx; font-weight: 600; color: #333; }
.quota-display { font-size: 24rpx; color: #07c160; font-weight: 600; }

.form {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-label { display: block; font-size: 28rpx; color: #333; font-weight: 600; margin-bottom: 16rpx; }
.form-picker { width: 100%; }

.picker-display {
  display: flex; align-items: center; justify-content: space-between;
  height: 72rpx; line-height: 72rpx; font-size: 28rpx; color: #333;
  border: 1rpx solid #e5e5e5; border-radius: 8rpx; padding: 0 16rpx; box-sizing: border-box;
}

.picker-display .placeholder { color: #bbb; }
.picker-arrow { font-size: 36rpx; color: #ccc; font-weight: 300; }

.form-input {
  width: 100%; height: 72rpx; font-size: 28rpx; color: #333;
  border: 1rpx solid #e5e5e5; border-radius: 8rpx; padding: 0 16rpx; box-sizing: border-box;
}

.form-textarea {
  width: 100%; min-height: 120rpx; font-size: 28rpx; color: #333;
  border: 1rpx solid #e5e5e5; border-radius: 8rpx; padding: 16rpx; box-sizing: border-box;
}

.form-hint { margin-bottom: 30rpx; font-size: 24rpx; color: #999; text-align: center; }

.submit-btn {
  width: 100%; height: 88rpx; line-height: 88rpx; background: #07c160;
  border: none; border-radius: 44rpx; font-size: 32rpx; font-weight: 600;
}

.submit-btn[disabled] { background: #ccc; }
.no-quota-hint { text-align: center; padding: 20rpx; font-size: 24rpx; color: #ff6b6b; }

/* 底部TabBar — 固定底部 */
.tabbar {
  display: flex; background: #fff; border-top: 1rpx solid #eee;
  flex-shrink: 0; padding-bottom: env(safe-area-inset-bottom);
}

.tabbar .tab-item {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 24rpx 0; font-size: 26rpx; color: #999;
}

.tabbar .tab-item.active { color: #07c160; font-weight: 600; }
