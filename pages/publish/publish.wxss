/* ========== 发布页面 ========== */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
}

/* ---------- 顶部导航 ---------- */
.header {
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
  flex-shrink: 0;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 30rpx;
  min-height: 44rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.quota-display {
  font-size: 24rpx;
  color: var(--color-accent);
  font-weight: 600;
  background: var(--color-accent-light);
  padding: 6rpx 18rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(58, 125, 116, 0.2);
}

/* ---------- 表单 ---------- */
.form {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.form-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border-light);
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 600;
  margin-bottom: 16rpx;
  position: relative;
  padding-left: 20rpx;
}

.form-label::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 20rpx;
  background: var(--color-primary-gradient);
  border-radius: 2rpx;
}

.form-picker { width: 100%; }

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-bg-input);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.picker-display:active {
  border-color: var(--color-primary);
}

.picker-display .placeholder {
  color: var(--color-text-tertiary);
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--color-text-tertiary);
  font-weight: 300;
}

.form-input {
  width: 100%;
  height: 76rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-bg-input);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.form-input:focus {
  border-color: var(--color-primary);
}

.form-textarea {
  width: 100%;
  min-height: 140rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-bg-input);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}

.form-textarea:focus {
  border-color: var(--color-primary);
}

/* 提示文字 */
.form-hint {
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  text-align: center;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--color-primary-gradient);
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 20rpx rgba(224, 112, 64, 0.3);
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(224, 112, 64, 0.2);
}

.submit-btn[disabled] {
  background: var(--color-bg-input);
  color: var(--color-text-tertiary);
  box-shadow: none;
}

.no-quota-hint {
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
  color: var(--color-danger);
  margin-top: -8rpx;
}

/* ---------- 底部TabBar ---------- */
.tabbar {
  display: flex;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  flex-shrink: 0;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 12rpx rgba(44, 40, 36, 0.04);
}

.tabbar .tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  position: relative;
  font-weight: 500;
}

.tabbar .tab-item.active {
  color: var(--color-primary);
  font-weight: 700;
}

.tabbar .tab-item.active::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary-gradient);
  border-radius: 0 0 4rpx 4rpx;
}
